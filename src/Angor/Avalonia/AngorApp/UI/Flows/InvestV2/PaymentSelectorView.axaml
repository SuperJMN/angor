<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:angorApp="clr-namespace:AngorApp"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="AngorApp.UI.Flows.InvestV2.PaymentSelectorView" x:DataType="angorApp:IPaymentSelectorViewModel">
    
    <Design.DataContext>
        <angorApp:PaymentSelectorViewModelSample />
    </Design.DataContext>
    <StackPanel Classes="BigGap">
        <Border>
            <EdgePanel StartContent="Amount to Invest" EndContent="{Binding AmountToInvest.DecimalString}" />
        </Border>
        <Separator />
        <ListBox ItemsSource="{Binding Wallets}" SelectedItem="{Binding SelectedWallet}" />
    </StackPanel>
</UserControl>